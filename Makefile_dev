PREFIX?=/Users/guillaum/.local
BINDIR=$(PREFIX)/bin

OCB_FLAGS = -use-ocamlfind -I src
OCB = ocamlbuild $(OCB_FLAGS)

VERSION = `cat VERSION`

all: native

native:
	$(OCB) -tag-line "true:	package(libgrew_dev)" grew_main.native

install: native
	cp grew_main.native $(BINDIR)/grew_dev

uninstall:
	rm -f $(BINDIR)/grew

.PHONY:	all clean byte native install uninstall

clean:
	$(OCB) -clean

info:
	@echo "BINDIR   = $(BINDIR)"
