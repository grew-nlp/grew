}


package external {
  rule fix2 (lex from "lex/ExtPos2.lex") {
    pattern {
      H[!ExtPos, lemma=lex.l0];
      H -[fixed]-> F1; F1[lemma=lex.l1];
    }
    without { H -[fixed]-> F }
    commands { H.ExtPos = lex.ExtPos; }
  }

  rule fix3 (lex from "lex/ExtPos3.lex") {
    pattern {
      H[!ExtPos, lemma=lex.l0];
      H -[fixed]-> F1; F1[lemma=lex.l1];
      H -[fixed]-> F2; F2[lemma=lex.l2];
    }
    without { H -[fixed]-> F }
    commands { H.ExtPos = lex.ExtPos }
  }

  rule fix4 (lex from "lex/ExtPos4.lex") {
    pattern {
      H[!ExtPos, lemma=lex.l0];
      H -[fixed]-> F1; F1[lemma=lex.l1];
      H -[fixed]-> F2; F2[lemma=lex.l2];
      H -[fixed]-> F3; F3[lemma=lex.l3];
    }
    without { H -[fixed]-> F }
    commands { H.ExtPos = lex.ExtPos }
  }

  rule fix5 {
    pattern {
      H[!ExtPos, lemma=lex.l0];
      H -[fixed]-> F1; F1[lemma=lex.l1];
      H -[fixed]-> F2; F2[lemma=lex.l2];
      H -[fixed]-> F3; F3[lemma=lex.l3];
      H -[fixed]-> F4; F4[lemma=lex.l4];
    }
    without { H -[fixed]-> F }
    commands { H.ExtPos = lex.ExtPos }
  }
#BEGIN lex
l0	l1	l2	l3	l4	ExtPos
à	le	jour	le	jour	ADV
#END
}

package nap {
  rule r (lex from "lex/ExtPos2.lex") {
    pattern {
      N1 [!ExtPos]; N2[]; N1 < N2;
    }
    without {
      N1[lemma=lex.l0]; N2[lemma=lex.l1];
    }
    commands {
      N1.ExtPos = "None";
    }
  }
}
